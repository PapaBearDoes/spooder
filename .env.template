# ==========================================================================
# Spooder — Emotive Spider Bot for Fluxer
# .env.template — Copy to .env and fill in values
# ==========================================================================

# ── Logging ───────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
SPOODER_LOG_LEVEL=INFO

# ── Command ───────────────────────────────────────────────────────────────
# The command prefix that triggers spooder (default: !spooder)
SPOODER_COMMAND_PREFIX=!spooder

# ── Container User ────────────────────────────────────────────────────────
# Match these to your host user for volume permission compatibility
PUID=1000
PGID=1000
